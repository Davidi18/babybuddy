# Coverage testing files.
.coverage
/htmlcov

# Environment configuration file.
.env

# Virtual environment files (pipenv may use this convention).
.venv
venv/

# IDE configuration files.
/.idea

# Node development dependencies.
/node_modules

# Python files.
*.pyc

# App static file directories (source, not compiled output).
/*/static
!/babybuddy/static

# Collected static output (STATIC_ROOT). This is generated by `collectstatic`
# at image-build/deploy time - it must not be committed. A committed copy goes
# stale (its hashed filenames stop matching the source), which makes pages
# reference CSS/JS URLs that 404 and load unstyled.
/static

# Django media root directory.
/media

# Data directory (SQLite database)
/data

# Pipfile.lock.
# Committing this file makes it difficult to support multiple Python versions as
# requirements can different between versions, but the Pipfile only supports
# locking to one version.
Pipfile.lock

# Documentation
/site

# macOS files
.DS_Store

# Devenv
.devenv*
devenv.local.nix

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml

.vscode

# Mock dbsettings (temporary for development)
/dbsettings/venv/
